{
  "name": "codeplug-tool",
  "private": true,
  "type": "module",
  "scripts": {
    "generate:abbreviations": "node scripts/generate-abbreviations.mjs",
    "predev": "npm run generate:abbreviations",
    "prebuild": "npm run generate:abbreviations",
    "pretest": "npm run generate:abbreviations",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:coverage": "npm run pretest && vitest run --coverage",
    "test:system": "npm run pretest && vitest run src/test/system src/components/ImportIntoActivePanel",
    "test:watch": "npm run pretest && vitest"
  },
  "dependencies": {
    "@mantine/core": "^9.3.2",
    "@mantine/hooks": "^9.3.2",
    "@tabler/icons-react": "^3.44.0",
    "@uiw/react-json-view": "^2.0.0-alpha.43",
    "fflate": "^0.8.3",
    "leaflet": "^1.9.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.6.2",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/leaflet": "^1.9.21",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.5.2",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.15",
    "postcss-preset-mantine": "^1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "prettier": "^3.8.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^6.3.5",
    "vitest": "^4.1.9"
  }
}
